<ui:FluentWindow x:Class="ML_Log_Analyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:ML_Log_Analyzer"
        mc:Ignorable="d"
        Title="ML Log Analyzer" Height="700" Width="1000" WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Home Panel -->
        <StackPanel x:Name="HomePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="ML Log Analyzer" FontSize="36" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <ui:Button x:Name="OpenLogButton" Content="Open Log" Appearance="Primary" 
                       Click="OpenLogButton_Click" HorizontalAlignment="Center" Width="200" Margin="0,0,0,30"/>

            <ui:Card Width="380" Margin="0">
                <StackPanel Margin="10">
                    <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="API Key:" Margin="0,0,0,5"/>
                    <ui:PasswordBox x:Name="ApiKeyBox" PlaceholderText="Enter your OpenRouter API key" Margin="0,0,0,15"/>

                    <TextBlock Text="Model:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ModelComboBox" Margin="0,0,0,15">
                        <ComboBoxItem Content="z-ai/glm-4.5-air" IsSelected="True"/>
                        <ComboBoxItem Content="google/gemma-3-27b-it"/>
                        <ComboBoxItem Content="nvidia/nemotron-3-super-120b-a12b"/>
                        <ComboBoxItem Content="minimax/minimax-m2.5"/>
                    </ComboBox>

                    <ui:Button x:Name="SaveSettingsButton" Content="Save Settings" Appearance="Secondary" 
                               Click="SaveSettingsButton_Click" HorizontalAlignment="Left"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Analysis Panel -->
        <Grid x:Name="AnalysisPanel" Visibility="Collapsed" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ML Log Analyzer" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <ui:Button x:Name="BackButton" Grid.Column="1" Content="Back" Appearance="Secondary" 
                           Click="BackButton_Click"/>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Log Content -->
                <ui:Card Grid.Column="0">
                    <DockPanel>
                        <TextBlock Text="Log Content" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,10"/>
                        <ui:TextBox x:Name="LogContentBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" 
                                   VerticalScrollBarVisibility="Auto" MinHeight="300"/>
                    </DockPanel>
                </ui:Card>

                <!-- Analysis Result -->
                <ui:Card Grid.Column="2">
                    <DockPanel>
                        <TextBlock Text="Analysis Result" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Top" Margin="0,0,0,10"/>
                        <ui:TextBox x:Name="AnalysisContentBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" 
                                   VerticalScrollBarVisibility="Auto" MinHeight="300"/>
                    </DockPanel>
                </ui:Card>
            </Grid>

            <!-- Bottom Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <ui:Button x:Name="StartButton" Content="Start Analysis" Appearance="Primary" 
                           Click="StartButton_Click" Width="150" Margin="0,0,15,0"/>
                <ui:Button x:Name="SaveButton" Content="Save Result" Appearance="Secondary" 
                           Click="SaveButton_Click" IsEnabled="False" Width="150" Margin="0,0,15,0"/>
                <ui:Button x:Name="CloseButton" Content="Close" Appearance="Danger" 
                           Click="CloseButton_Click" Width="150"/>
                <TextBlock x:Name="LoadingText" Text="Analyzing..." Visibility="Collapsed" 
                           FontSize="14" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>